# Streamlit Cloud用 Secretsテンプレート
# 実際の値はStreamlit Cloudの「App settings → Secrets」に貼り付ける
# このファイルはサンプル。.streamlit/secrets.toml はgit除外

DATABASE_URL = "postgresql://postgres.xxx:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres"

X_API_KEY = "your_x_api_key"
X_API_SECRET = "your_x_api_secret"
X_ACCESS_TOKEN = "your_x_access_token"
X_ACCESS_TOKEN_SECRET = "your_x_access_token_secret"

OOW_API_KEY = "your_myaku_api_key"
OOW_API_SECRET = "your_myaku_api_secret"
OOW_ACCESS_TOKEN = "your_myaku_access_token"
OOW_ACCESS_TOKEN_SECRET = "your_myaku_access_token_secret"
